# Copy to server/.env (gitignored) and fill in. In production these come from
# the platform's environment variables instead.
ENV=dev
PORT=8000

# Postgres — either a single DATABASE_URL, or the PG_* fields below.
# DATABASE_URL=postgres://user:pass@host:25060/db?sslmode=require
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres
PG_USERNAME=postgres
PG_PASSWORD=
# "require" for managed DBs (e.g. DigitalOcean), "disable" for a local Postgres.
# Defaults (when unset) target a managed DB: PG_PORT=25060, PG_SSL=require.
PG_SSL=disable

# Bot account (optional locally). Leave BSKY_USERNAME=empty to disable the bot.
BSKY_USERNAME=empty
BSKY_PASSWORD=empty
BSKY_HOST=https://bsky.social

# Public hostname (for the feed-generator DID document)
HOSTNAME=poll.blue
