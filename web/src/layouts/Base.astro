---
import "../styles/global.css";
import AccountMenu from "../components/AccountMenu.tsx";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "poll.blue — polls for Bluesky",
  description = "Create polls on Bluesky. Sign in with your account, post a poll, and watch the results roll in.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#1185fe" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="relative z-10 flex min-h-[100dvh] flex-col">
      <header class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6">
        <a href="/" class="group flex items-center gap-2.5">
          <span
            class="grid h-9 w-9 place-items-center rounded-xl text-white shadow-[var(--shadow-lift)]"
            style="background: linear-gradient(160deg, var(--color-brand), var(--color-brand-deep));"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 13h3v6H5zM10.5 8h3v11h-3zM16 4h3v15h-3z" fill="currentColor" />
            </svg>
          </span>
          <span class="font-display text-xl font-bold tracking-tight">
            poll<span style="color: var(--color-brand)">.blue</span>
          </span>
        </a>
        <nav class="flex items-center gap-2 text-sm font-semibold text-[var(--color-ink-soft)]">
          <a class="hidden rounded-full px-4 py-2 transition-colors hover:text-[var(--color-brand-deep)] sm:block" href="/create">Create a poll</a>
          <AccountMenu client:only="preact" />
        </nav>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="mx-auto w-full max-w-5xl px-6 py-10">
        <div
          class="flex flex-col items-start justify-between gap-4 border-t pt-6 text-sm text-[var(--color-ink-soft)] sm:flex-row sm:items-center"
          style="border-color: var(--color-line)"
        >
          <p>
            poll.blue — run by
            <a class="font-semibold text-[var(--color-brand-deep)] hover:underline" href="https://bsky.app/profile/netwatch.dev">@netwatch.dev</a>,
            originally by
            <a class="font-semibold text-[var(--color-brand-deep)] hover:underline" href="https://bsky.app/profile/epistemic.horse">@epistemic.horse</a>.
          </p>
          <p class="text-[var(--color-ink-faint)]">Built on the AT Protocol.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
