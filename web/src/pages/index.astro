---
import Base from "../layouts/Base.astro";

const steps = [
  {
    n: "01",
    title: "Sign in with Bluesky",
    body: "Authorize with OAuth — your password never touches our servers. We only ever act on your behalf to post the poll.",
  },
  {
    n: "02",
    title: "Write your question",
    body: "Up to four options. We compose a clean, tappable poll post and publish it straight to your own account.",
  },
  {
    n: "03",
    title: "Watch it roll in",
    body: "Each option is a link people tap to vote. Live tallies, a shareable results page, and an automatic recap after 24 hours.",
  },
];

const demoOptions = [
  { label: "Tabs", pct: 46 },
  { label: "Spaces", pct: 31 },
  { label: "I use both, I'm a monster", pct: 23 },
];
---

<Base>
  <!-- Hero -->
  <section class="mx-auto grid max-w-5xl gap-12 px-6 pt-10 pb-20 md:grid-cols-[1.05fr_0.95fr] md:items-center md:pt-16">
    <div>
      <p class="pill rise" style="animation-delay: 40ms">
        <span class="inline-block h-1.5 w-1.5 rounded-full" style="background: var(--color-brand)"></span>
        Polls, native to the AT Protocol
      </p>
      <h1 class="rise mt-6 text-5xl leading-[0.98] sm:text-6xl md:text-[4.25rem]" style="animation-delay: 90ms">
        Ask Bluesky<br />
        <span style="color: var(--color-brand)">anything.</span>
      </h1>
      <p class="rise mt-6 max-w-md text-lg leading-relaxed text-[var(--color-ink-soft)]" style="animation-delay: 150ms">
        Spin up a poll in seconds and post it straight from your own account.
        OAuth sign-in, no passwords, no middleman — just you and your followers.
      </p>
      <div class="rise mt-8 flex flex-wrap items-center gap-3" style="animation-delay: 210ms">
        <a href="/create" class="btn btn-primary text-base">
          Create a poll
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#how" class="btn btn-ghost text-base">See how it works</a>
      </div>
    </div>

    <!-- Live-looking demo card -->
    <div class="rise" style="animation-delay: 260ms">
      <div class="card relative overflow-hidden p-6 sm:p-7">
        <div
          class="pointer-events-none absolute -right-16 -top-16 h-44 w-44 rounded-full blur-2xl"
          style="background: radial-gradient(circle, rgba(17,133,254,0.25), transparent 70%)"
        >
        </div>
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-full" style="background: linear-gradient(135deg, #1185fe, #073a86)"></div>
          <div class="leading-tight">
            <p class="font-semibold">you.bsky.social</p>
            <p class="text-sm text-[var(--color-ink-faint)]">via poll.blue</p>
          </div>
        </div>
        <p class="mt-4 text-lg font-semibold">Tabs or spaces? Settle it.</p>

        <div class="mt-4 space-y-2.5">
          {demoOptions.map((o, i) => (
            <div class="relative overflow-hidden rounded-xl border" style="border-color: var(--color-line)">
              <div
                class="bar-fill absolute inset-y-0 left-0"
                style={`width:${o.pct}%; animation-delay:${360 + i * 140}ms; background: var(--color-brand-tint)`}
              >
              </div>
              <div class="relative flex items-center justify-between px-4 py-2.5">
                <span class="font-medium">{o.label}</span>
                <span class="font-display font-bold" style="color: var(--color-brand-deep)">{o.pct}%</span>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-4 text-sm text-[var(--color-ink-faint)]">📊 1,204 votes · ends in 18h</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="mx-auto max-w-5xl px-6 py-16">
    <h2 class="text-3xl sm:text-4xl">Three taps to a live poll.</h2>
    <p class="mt-3 max-w-xl text-[var(--color-ink-soft)]">
      poll.blue is built directly on the AT Protocol. The poll lives on <em>your</em> account — we just make it pretty and count the votes.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-3">
      {steps.map((s) => (
        <div class="card flex flex-col gap-3 p-6">
          <span class="font-display text-sm font-bold tracking-widest" style="color: var(--color-brand)">{s.n}</span>
          <h3 class="text-xl">{s.title}</h3>
          <p class="text-[var(--color-ink-soft)]">{s.body}</p>
        </div>
      ))}
    </div>

    <div class="card mt-10 flex flex-col items-center gap-5 p-10 text-center sm:p-14">
      <h2 class="max-w-xl text-3xl sm:text-4xl">Ready when you are.</h2>
      <p class="max-w-md text-[var(--color-ink-soft)]">No sign-up, no app password. Just authorize with Bluesky and post.</p>
      <a href="/create" class="btn btn-primary text-base">Create your first poll</a>
    </div>
  </section>
</Base>
