---
import Base from "../layouts/Base.astro";
import CreatePoll from "../components/CreatePoll.tsx";
---

<Base title="Create a poll — poll.blue" description="Post a poll to Bluesky from your own account.">
  <section class="mx-auto max-w-5xl px-6 pt-8 pb-20">
    <div class="mb-8 max-w-xl">
      <h1 class="text-4xl sm:text-5xl">Create a poll</h1>
      <p class="mt-3 text-lg text-[var(--color-ink-soft)]">
        All it takes is a question, an Atmosphere account, and the will to post. Go on, try it. 
      </p>
    </div>
    <CreatePoll client:only="preact" />
  </section>
</Base>
